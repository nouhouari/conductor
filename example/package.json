{
  "name": "conductor-example",
  "version": "0.1.0",
  "private": true,
  "description": "Example project showing how to use the Conductor test framework",
  "scripts": {
    "test": "cucumber-js",
    "test:web": "cucumber-js --profile web",
    "test:api": "cucumber-js --profile api",
    "test:mobile": "cucumber-js --profile mobile",
    "test:cross": "cucumber-js --tags @cross-platform",
    "test:dry-run": "cucumber-js --dry-run",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "dependencies": {
    "conductor": "file:..",
    "@cucumber/cucumber": "^11.0.0",
    "allure-cucumberjs": "^3.0.0",
    "playwright": "^1.44.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "@types/node": "^20.0.0"
  }
}
